generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String?
  preferredModes     String[] @default([])
  avoidMotorcycleRain Boolean @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  routeHistory RouteHistory[]

  @@map("profiles")
}

model WeatherCache {
  id               String   @id @default(cuid())
  lat              Float
  lng              Float
  intensity        String
  rainfallMmPerHour Float
  description      String
  source           String
  fetchedAt        DateTime @default(now())
  expiresAt        DateTime

  @@index([lat, lng])
  @@index([expiresAt])
  @@map("weather_cache")
}

model TransitStop {
  id       String  @id
  name     String
  lat      Float
  lng      Float
  type     String
  parentId String?

  @@index([lat, lng])
  @@map("transit_stops")
}

model TransitRoute {
  id             String   @id
  shortName      String
  longName       String
  type           String
  stopIds        String[]
  fareMin        Int      @default(0)
  fareMax        Int      @default(0)
  fareNote       String   @default("")
  operatingHours String   @default("")
  frequency      Int      @default(15)
  color          String   @default("#888888")

  @@map("transit_routes")
}

model RouteHistory {
  id               String   @id @default(cuid())
  profileId        String?
  profile          Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  originLat        Float
  originLng        Float
  destinationLat   Float
  destinationLng   Float

  chosenMode       String
  weatherIntensity String
  discomfortScore  Float
  routeLabel       String

  createdAt        DateTime @default(now())

  @@index([profileId])
  @@index([createdAt])
  @@map("routes_history")
}
